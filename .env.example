# ==============================================================================
# Inventory Management ERP — Environment Variables
# Copy this file to .env (root) and/or apps/web/.env.local, apps/api/.env
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase (cloud project — no local Supabase instance is used)
# Project ID: dmoqvnkdnrclojhcpnre
# ------------------------------------------------------------------------------
SUPABASE_PROJECT_ID=dmoqvnkdnrclojhcpnre
SUPABASE_URL=https://dmoqvnkdnrclojhcpnre.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key: server-side only, NEVER expose to the browser/frontend
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Direct Postgres connection string (used by packages/database for migrations)
DATABASE_URL=postgresql://postgres:your-db-password@db.dmoqvnkdnrclojhcpnre.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=your-db-password

# ------------------------------------------------------------------------------
# apps/web (Next.js) — public vars must be prefixed NEXT_PUBLIC_
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://dmoqvnkdnrclojhcpnre.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001
# Used to build absolute redirect URLs for Supabase email links (password reset, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# apps/api (NestJS)
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=debug

# JWT (used for API-issued tokens / verifying Supabase JWTs)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
